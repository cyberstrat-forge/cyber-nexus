# ========================================
# Cyber Nexus .gitignore
# ========================================

# ----------------------------------------
# Dependencies
# ----------------------------------------
node_modules/

# ----------------------------------------
# Build outputs
# ----------------------------------------
dist/
build/
*.js.map
*.d.ts.map

# ----------------------------------------
# IDE & Editors
# ----------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ----------------------------------------
# OS generated files
# ----------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ----------------------------------------
# Logs
# ----------------------------------------
logs/
*.log
npm-debug.log*

# ----------------------------------------
# Environment & Secrets
# ----------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ----------------------------------------
# Test & Coverage
# ----------------------------------------
coverage/
.nyc_output/
test-data/
test-temp/

# ----------------------------------------
# Plugin runtime data
# ----------------------------------------
# Intelligence output (user generated)
.intel/
.themes/

# Preprocessing metadata
converted/.meta/

# State files (user generated)
state.json

# ----------------------------------------
# Temporary files
# ----------------------------------------
tmp/
temp/
*.tmp
*.temp

# ----------------------------------------
# Package manager
# ----------------------------------------
# Note: We commit package-lock.json for reproducibility

# ----------------------------------------
# TypeScript
# ----------------------------------------
*.tsbuildinfo

# ----------------------------------------
# Debug
# ----------------------------------------
.debug/

# ----------------------------------------
# Development
# ----------------------------------------
# Git worktrees for isolated development
.worktrees/