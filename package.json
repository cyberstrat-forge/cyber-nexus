{
  "name": "cyber-nexus",
  "version": "1.0.0",
  "description": "Claude Code plugin collection for cybersecurity strategic planning",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0"
  },
  "commitlint": {
    "extends": ["@commitlint/config-conventional"],
    "rules": {
      "scope-enum": [
        1,
        "always",
        ["market-radar", "plugin", "docs", "ci"]
      ]
    }
  }
}