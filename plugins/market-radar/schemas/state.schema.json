{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "state.schema.json",
  "title": "Intelligence Processing State Schema",
  "description": "JSON Schema for state.json validation in intel-distill workflow",
  "type": "object",
  "required": ["version", "updated_at", "queue", "processed", "stats"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "State file format version (e.g., 1.0)"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp (ISO 8601 format)"
    },
    "queue": {
      "$ref": "#/definitions/queue"
    },
    "processed": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/processed_entry"
      },
      "description": "Map of processed file paths to their metadata"
    },
    "stats": {
      "$ref": "#/definitions/stats"
    }
  },
  "definitions": {
    "queue": {
      "type": "object",
      "required": ["pending", "processing", "failed"],
      "additionalProperties": false,
      "properties": {
        "pending": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/pending_item"
          },
          "description": "Files waiting to be processed"
        },
        "processing": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/processing_entry"
          },
          "description": "Files currently being processed"
        },
        "failed": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/failed_entry"
          },
          "description": "Files that failed processing"
        }
      }
    },
    "pending_item": {
      "type": "object",
      "required": ["path", "content_hash"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Relative file path"
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{32}$",
          "description": "MD5 hash of file content at scan time"
        }
      }
    },
    "processing_entry": {
      "type": "object",
      "required": ["started_at", "session", "content_hash"],
      "additionalProperties": false,
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time",
          "description": "Processing start timestamp (ISO 8601)"
        },
        "session": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{6}$",
          "description": "Session ID (YYYYMMDD-HHMMSS)"
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{32}$",
          "description": "MD5 hash of file content being processed"
        }
      }
    },
    "failed_entry": {
      "type": "object",
      "required": ["error", "failed_at", "retries", "content_hash"],
      "additionalProperties": false,
      "properties": {
        "error": {
          "type": "string",
          "description": "Error message"
        },
        "failed_at": {
          "type": "string",
          "format": "date-time",
          "description": "Failure timestamp (ISO 8601)"
        },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1,
          "description": "Number of retry attempts (max 1)"
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{32}$",
          "description": "MD5 hash of file content at failure time"
        },
        "validation_errors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Schema validation errors (if applicable)"
        }
      }
    },
    "processed_entry": {
      "type": "object",
      "required": ["content_hash", "processed_at", "intelligence_count", "session"],
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{32}$",
          "description": "MD5 hash of source file content for change detection"
        },
        "source_mtime": {
          "type": "integer",
          "minimum": 0,
          "description": "Source file modification time (Unix timestamp) - retained for backward compatibility"
        },
        "processed_at": {
          "type": "string",
          "format": "date-time",
          "description": "Processing completion timestamp (ISO 8601)"
        },
        "intelligence_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of intelligence items extracted"
        },
        "output_files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of generated output file paths"
        },
        "session": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{6}$",
          "description": "Session ID (YYYYMMDD-HHMMSS)"
        }
      }
    },
    "stats": {
      "type": "object",
      "required": ["total_files", "total_intelligence", "last_run"],
      "additionalProperties": false,
      "properties": {
        "total_files": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of files processed"
        },
        "total_intelligence": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of intelligence items extracted"
        },
        "last_run": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "Last processing run timestamp (ISO 8601 or null)"
        }
      }
    }
  }
}