{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "intelligence-output.schema.json",
  "title": "Intelligence Output Schema",
  "description": "JSON Schema for intelligence-analyzer agent output validation (v3.0 - with metadata inheritance)",
  "type": "object",
  "required": [
    "source_file",
    "has_strategic_value",
    "intelligence_items",
    "source_meta",
    "processing_notes"
  ],
  "additionalProperties": false,
  "properties": {
    "source_file": {
      "type": "string",
      "description": "Relative path to the source file"
    },
    "has_strategic_value": {
      "type": "boolean",
      "description": "Whether strategic value intelligence was found"
    },
    "intelligence_items": {
      "type": "array",
      "description": "Array of intelligence items (can be empty)",
      "items": {
        "$ref": "#/definitions/intelligence_item"
      }
    },
    "source_meta": {
      "$ref": "#/definitions/source_meta"
    },
    "processing_notes": {
      "type": "string",
      "description": "Processing notes and explanations"
    }
  },
  "definitions": {
    "intelligence_item": {
      "type": "object",
      "required": [
        "domain",
        "title",
        "filename",
        "keywords",
        "dedup_check",
        "frontmatter",
        "content",
        "review_needed"
      ],
      "additionalProperties": false,
      "properties": {
        "domain": {
          "type": "string",
          "enum": [
            "Threat-Landscape",
            "Industry-Analysis",
            "Vendor-Intelligence",
            "Emerging-Tech",
            "Customer-Market",
            "Policy-Regulation",
            "Capital-Investment"
          ],
          "description": "Intelligence domain identifier"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Concise intelligence title"
        },
        "filename": {
          "type": "string",
          "pattern": "^\\d{8}-[a-z0-9-]+\\.md$",
          "description": "Suggested filename (format: YYYYMMDD-subject-feature.md)"
        },
        "keywords": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "type": "string"
          },
          "description": "Keyword list (3-5 items)"
        },
        "dedup_check": {
          "$ref": "#/definitions/dedup_check"
        },
        "frontmatter": {
          "$ref": "#/definitions/frontmatter"
        },
        "content": {
          "type": "string",
          "minLength": 50,
          "description": "Markdown content body"
        },
        "review_needed": {
          "type": "boolean",
          "description": "Whether manual review is needed"
        },
        "review_notes": {
          "type": ["string", "null"],
          "description": "Review notes (optional)"
        }
      }
    },
    "dedup_check": {
      "type": "object",
      "required": ["primary_entity", "timeframe", "key_facts"],
      "additionalProperties": false,
      "properties": {
        "primary_entity": {
          "type": "string",
          "description": "Primary entity name (company, technology, organization, etc.)"
        },
        "timeframe": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}$",
          "description": "Time range (YYYY-MM format)"
        },
        "key_facts": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": {
            "type": "string"
          },
          "description": "Key facts list (2-3 items)"
        }
      }
    },
    "frontmatter": {
      "type": "object",
      "required": [
        "intelligence_id",
        "title",
        "created_date",
        "primary_domain",
        "secondary_domains",
        "security_relevance",
        "tags",
        "item_id",
        "item_title",
        "fetched_at",
        "archived_file",
        "converted_file",
        "generated_by",
        "generated_session"
      ],
      "additionalProperties": true,
      "properties": {
        "intelligence_id": {
          "type": "string",
          "pattern": "^[a-z]+-\\d{8}-\\d{3}$",
          "description": "Intelligence card unique ID (format: {domain_prefix}-{YYYYMMDD}-{seq})"
        },
        "title": {
          "type": "string",
          "description": "Intelligence title"
        },
        "created_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Card creation date (YYYY-MM-DD format)"
        },
        "primary_domain": {
          "type": "string",
          "enum": [
            "Threat-Landscape",
            "Industry-Analysis",
            "Vendor-Intelligence",
            "Emerging-Tech",
            "Customer-Market",
            "Policy-Regulation",
            "Capital-Investment"
          ],
          "description": "Primary domain"
        },
        "secondary_domains": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Threat-Landscape",
              "Industry-Analysis",
              "Vendor-Intelligence",
              "Emerging-Tech",
              "Customer-Market",
              "Policy-Regulation",
              "Capital-Investment"
            ]
          },
          "description": "Secondary domains"
        },
        "security_relevance": {
          "type": "string",
          "enum": ["high", "medium"],
          "description": "Security relevance level"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Nested tags with namespace prefixes (e.g., 'geo:china', 'business:MSSP', 'tech:ai-security')"
        },
        "item_id": {
          "type": "string",
          "pattern": "^item_[a-f0-9]{8}$",
          "description": "Item ID from collection stage (format: item_{8hex})"
        },
        "item_title": {
          "type": "string",
          "description": "Original title from collection stage"
        },
        "author": {
          "type": "string",
          "description": "Author information (optional, inherited from collection)"
        },
        "original_url": {
          "type": "string",
          "format": "uri",
          "description": "Original article URL (optional, inherited from collection)"
        },
        "published_at": {
          "type": "string",
          "description": "Original publication time (ISO 8601 format, optional)"
        },
        "fetched_at": {
          "type": "string",
          "description": "Fetch time from collection stage (ISO 8601 format)"
        },
        "completeness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Content completeness score 0-1 (optional, inherited from collection)"
        },
        "archived_file": {
          "type": "string",
          "pattern": "^\\[\\[.+\\]\\]$",
          "description": "Archived file path (WikiLink format: [[archive/YYYY/MM/filename]])"
        },
        "converted_file": {
          "type": "string",
          "pattern": "^\\[\\[.+\\]\\]$",
          "description": "Converted file path (WikiLink format: [[converted/YYYY/MM/filename.md]])"
        },
        "source_id": {
          "type": "string",
          "description": "Intelligence source ID (optional, inherited from collection)"
        },
        "source_name": {
          "type": "string",
          "description": "Intelligence source name (optional, inherited from collection)"
        },
        "source_url": {
          "type": "string",
          "format": "uri",
          "description": "Intelligence source URL (optional, inherited from collection)"
        },
        "source_tier": {
          "type": "string",
          "enum": ["T0", "T1", "T2", "T3"],
          "description": "Source tier rating (T0=official, T1=well-known, T2=industry, T3=general)"
        },
        "source_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Source quality score 0-100 (optional, inherited from collection)"
        },
        "review_status": {
          "type": "string",
          "enum": ["passed", "pending", "approved", "rejected"],
          "description": "Review status: passed (auto-approved by agent), pending (needs user review), approved (user-approved), rejected (declined by agent or user)"
        },
        "generated_by": {
          "type": "string",
          "const": "intelligence-analyzer",
          "description": "Generator identifier (fixed value)"
        },
        "generated_session": {
          "type": "string",
          "pattern": "^\\d{8}-\\d{6}$",
          "description": "Session ID (YYYYMMDD-HHMMSS format)"
        }
      }
    },
    "source_meta": {
      "type": "object",
      "required": ["title", "published"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": ["string", "null"],
          "description": "Original document title"
        },
        "published": {
          "type": ["string", "null"],
          "description": "Source document published date (YYYY-MM-DD format or null)"
        }
      }
    }
  }
}