{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agent-result.schema.json",
  "title": "Agent Result Schema",
  "description": "JSON Schema for intelligence-analyzer agent lightweight result validation (v2.1 - multi-card support)",
  "type": "object",
  "required": [
    "status",
    "source_file",
    "has_strategic_value",
    "source_meta",
    "processing_notes"
  ],
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"],
      "description": "Processing status"
    },
    "source_file": {
      "type": "string",
      "description": "Relative path to the source file"
    },
    "has_strategic_value": {
      "type": ["boolean", "null"],
      "description": "Whether strategic value intelligence was found. null = needs review"
    },
    "review_reason": {
      "type": "string",
      "description": "Reason for requiring review (when has_strategic_value is null)"
    },
    "intelligence_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of intelligence cards extracted (no upper limit, based on source document content)"
    },
    "intelligence_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z-]*-\\d{8}-\\d{3}$"
      },
      "description": "List of generated intelligence card IDs (format: {domain}-{YYYYMMDD}-{seq})"
    },
    "output_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of generated output file paths (relative to output directory)"
    },
    "cards": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/intelligence_card"
      },
      "description": "Details of each generated intelligence card"
    },
    "source_meta": {
      "type": "object",
      "required": ["title", "published"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": ["string", "null"],
          "description": "Original document title"
        },
        "published": {
          "type": ["string", "null"],
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Source document published date (YYYY-MM-DD format or null)"
        }
      }
    },
    "processing_notes": {
      "type": "string",
      "description": "Processing notes and explanations"
    },
    "error_code": {
      "type": "string",
      "description": "Error code (required when status=error)",
      "enum": [
        "READ_FAILED",
        "CONVERSION_FAILED",
        "WRITE_FAILED",
        "ANALYSIS_FAILED",
        "TOOL_UNAVAILABLE"
      ]
    },
    "error_message": {
      "type": "string",
      "description": "Detailed error message (required when status=error)"
    }
  },
  "definitions": {
    "intelligence_card": {
      "type": "object",
      "required": ["intelligence_id", "primary_domain", "output_file"],
      "additionalProperties": false,
      "properties": {
        "intelligence_id": {
          "type": "string",
          "pattern": "^[a-z][a-z-]*-\\d{8}-\\d{3}$",
          "description": "Intelligence card ID (format: {domain}-{YYYYMMDD}-{seq})"
        },
        "primary_domain": {
          "type": "string",
          "enum": [
            "Threat-Landscape",
            "Industry-Analysis",
            "Vendor-Intelligence",
            "Emerging-Tech",
            "Customer-Market",
            "Policy-Regulation",
            "Capital-Investment"
          ],
          "description": "Primary intelligence domain"
        },
        "secondary_domains": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Threat-Landscape",
              "Industry-Analysis",
              "Vendor-Intelligence",
              "Emerging-Tech",
              "Customer-Market",
              "Policy-Regulation",
              "Capital-Investment"
            ]
          },
          "description": "Secondary domains if applicable"
        },
        "output_file": {
          "type": "string",
          "description": "Output file path relative to output directory"
        },
        "title": {
          "type": "string",
          "description": "Intelligence card title"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "success" },
          "has_strategic_value": { "const": true }
        },
        "required": ["status", "has_strategic_value"]
      },
      "then": {
        "required": ["intelligence_count", "intelligence_ids", "output_files", "cards"]
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "success" },
          "has_strategic_value": { "type": "null" }
        },
        "required": ["status", "has_strategic_value"]
      },
      "then": {
        "required": ["review_reason"]
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "error" }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["error_code", "error_message"]
      }
    }
  ]
}